# Shared configuration for every script under azure/.
# Scripts source this file; override any value by exporting it before running.

# -------- Azure target --------
AZ_LOCATION="${AZ_LOCATION:-westeurope}"
AZ_RESOURCE_GROUP="${AZ_RESOURCE_GROUP:-rg-vehicle-configurator}"
AZ_ENVIRONMENT="${AZ_ENVIRONMENT:-vc-env}"
AZ_LOG_ANALYTICS="${AZ_LOG_ANALYTICS:-vc-logs}"

# -------- Container app names --------
# Kept identical to the docker-compose service names so nginx's
# upstream ("backend") and the backend's SPRING_DATASOURCE_URL
# ("database") resolve via ACA's internal DNS without any changes.
APP_DATABASE="${APP_DATABASE:-database}"
APP_BACKEND="${APP_BACKEND:-backend}"
APP_FRONTEND="${APP_FRONTEND:-frontend}"

# -------- Images (GitHub Container Registry, public) --------
GHCR_OWNER="${GHCR_OWNER:-fbrase-itk}"
IMAGE_TAG="${IMAGE_TAG:-latest}"
IMAGE_DATABASE="${IMAGE_DATABASE:-ghcr.io/${GHCR_OWNER}/vehicle_configurator-database:${IMAGE_TAG}}"
IMAGE_BACKEND="${IMAGE_BACKEND:-ghcr.io/${GHCR_OWNER}/vehicle_configurator-backend:${IMAGE_TAG}}"
IMAGE_FRONTEND="${IMAGE_FRONTEND:-ghcr.io/${GHCR_OWNER}/vehicle_configurator-frontend:${IMAGE_TAG}}"

# -------- OIDC / AAD bootstrap (used only by 00-bootstrap-oidc.sh) --------
AAD_APP_NAME="${AAD_APP_NAME:-gh-vehicle-configurator-deployer}"
GH_REPO="${GH_REPO:-fbrase-itk/vehicle_configurator}"
GH_DEPLOY_REF="${GH_DEPLOY_REF:-refs/heads/main}"

# -------- Database credentials (NOT secrets — demo only) --------
# Match docker/env/database.env and docker/env/backend.env so the same
# images behave identically locally and on Azure.
MYSQL_ROOT_PASSWORD="${MYSQL_ROOT_PASSWORD:-rootpassword}"
MYSQL_DATABASE="${MYSQL_DATABASE:-configurator}"
MYSQL_USER="${MYSQL_USER:-configurator}"
MYSQL_PASSWORD="${MYSQL_PASSWORD:-configurator123}"
